<% content_for :title, "Import batch ##{@import_batch.id}" %>

<div class="w-full max-w-3xl">
  <h1 class="text-2xl font-semibold mb-2">Import batch #<%= @import_batch.id %></h1>
  <p class="text-sm text-gray-600 mb-4">
    Data source: <strong><%= @import_batch.data_source.name %></strong>
    (<%= @import_batch.data_source.kind %>)
  </p>

  <% if flash[:notice].present? %>
    <div class="mb-4 p-3 bg-green-50 text-green-800 rounded"><%= flash[:notice] %></div>
  <% end %>

  <div class="mb-6">
    <h2 class="text-lg font-medium mb-2">Status</h2>
    <p>
      <span class="px-2 py-1 text-xs rounded
        <%= { 'queued' => 'bg-gray-200', 'processing' => 'bg-yellow-100',
              'complete' => 'bg-green-100', 'failed' => 'bg-red-100' }[@import_batch.status] %>">
        <%= @import_batch.status %>
      </span>
      <% if @import_batch.started_at %>
        &nbsp;started <%= @import_batch.started_at.iso8601 %>
      <% end %>
      <% if @import_batch.completed_at %>
        &nbsp;completed <%= @import_batch.completed_at.iso8601 %>
      <% end %>
    </p>
  </div>

  <div class="mb-6">
    <h2 class="text-lg font-medium mb-2">Counters</h2>
    <table class="w-full text-left border-collapse">
      <tbody>
        <tr class="border-b"><td class="py-1 pr-4">Rows in file</td><td><%= @import_batch.row_count %></td></tr>
        <tr class="border-b"><td class="py-1 pr-4">Processed</td><td><%= @import_batch.processed_count %></td></tr>
        <tr class="border-b"><td class="py-1 pr-4">Successful</td><td><%= @import_batch.success_count %></td></tr>
        <tr class="border-b"><td class="py-1 pr-4">Duplicates (skipped)</td><td><%= @import_batch.duplicate_count %></td></tr>
        <tr class="border-b"><td class="py-1 pr-4">Errors</td><td><%= @import_batch.error_count %></td></tr>
      </tbody>
    </table>
  </div>

  <% if @import_batch.error_log.present? %>
    <div class="mb-6">
      <h2 class="text-lg font-medium mb-2">Row errors (<%= @import_batch.error_log.length %>)</h2>
      <table class="w-full text-left border-collapse text-sm">
        <thead>
          <tr class="border-b">
            <th class="py-2 pr-4">Row #</th>
            <th class="py-2 pr-4">External ID</th>
            <th class="py-2 pr-4">Error</th>
          </tr>
        </thead>
        <tbody>
          <% @import_batch.error_log.first(50).each do |entry| %>
            <tr class="border-b">
              <td class="py-1 pr-4"><%= entry["row_number"] %></td>
              <td class="py-1 pr-4"><%= entry["external_id"] %></td>
              <td class="py-1 pr-4 font-mono text-xs"><%= entry["error"] %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
      <% if @import_batch.error_log.length > 50 %>
        <p class="text-xs text-gray-600 mt-2">Showing first 50 of <%= @import_batch.error_log.length %> errors.</p>
      <% end %>
    </div>
  <% end %>

  <div class="flex gap-3 mt-6">
    <%= link_to "Back to data sources", data_sources_path, class: "px-4 py-2 border rounded hover:bg-gray-50" %>
    <%= link_to "Upload another", new_import_batch_path, class: "px-4 py-2 border rounded hover:bg-gray-50" %>
  </div>
</div>
